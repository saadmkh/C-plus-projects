#include <iostream>
using namespace std;

int main() {

    string pass;

    bool upper = false;
    bool lower = false;
    bool digit = false;
    bool special = false;

    cout << "Enter password: ";
    getline(cin, pass);

    if(pass.length() < 8){
        cout << "password is too short";
        return 0;
    }

    for(char ch : pass)
    {
        if(isupper(ch))
            upper = true;

        else if(islower(ch))
            lower = true;

        else if(isdigit(ch))
            digit = true;

        else
            special = true;
    }

    int score = upper + lower + digit + special;

    if(score == 4)
        cout << "Strong password";

    else if(score == 3)
        cout << "Medium password";

    else
        cout << "Weak password";

    return 0;
}
