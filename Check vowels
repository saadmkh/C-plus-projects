#include <iostream>
using namespace std;

int main() {
    string text;
    int vowels = 0;

    cout << "Enter a sentence: ";
    getline(cin, text);

    for (int i = 0; i < text.length(); i++) {
        char ch = text[i];

        if (ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u' ||
            ch == 'A' || ch == 'E' || ch == 'I' || ch == 'O' || ch == 'U') {
            vowels++;
        }
    }

    cout << "number of vowels = " << vowels << endl;

    return 0;
}
