#include <iostream>
using namespace std;

int main() {

    int arr[10];
    bool found = false;

    cout << "Enter 10 numbers:\n";

    for (int i = 0; i < 10; i++) {
        cin >> arr[i];
    }

    for (int i = 0; i < 10; i++) {
        for (int j = i + 1; j < 10; j++) {

            if (arr[i] == arr[j]) {
                cout << "Duplicate found: " << arr[i] << endl;
                found = true;
                break;
            }
        }
        if (found) break;
    }

    if (!found) {
        cout << "No duplicates found\n";
    }

    return 0;
}
