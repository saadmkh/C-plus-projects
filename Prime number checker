#include <iostream>
using namespace std;

int main() {
    int num, i;
    bool prime = true;

    cout << "Enter number: ";
    cin >> num;

    if (num <= 1)
        prime = false;

    for (i = 2; i < num; i++) {
        if (num % i == 0) {
            prime = false;
            break;
        }
    }

    if (prime)
        cout << "Prime number";
    else
        cout << "Not prime";

    return 0;
}
