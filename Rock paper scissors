#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;

int main() {

    srand(time(0));

    int user, comp;
    char again;

    do {
        cout << "\n1. Rock\n2. Paper\n3. Scissors\n";
        cout << "Enter your choice: ";
        cin >> user;

        comp = rand() % 3 + 1;

        cout << "Computer chose: ";

        if (comp == 1) cout << "Rock\n";
        else if (comp == 2) cout << "Paper\n";
        else cout << "Scissors\n";


        if (user == comp)
            cout << "Draw\n";

        else if ((user == 1 && comp == 3) ||
                 (user == 2 && comp == 1) ||
                 (user == 3 && comp == 2))
            cout << "You win\n";

        else
            cout << "Computer wins\n";


        cout << "Play again? (y/n): ";
        cin >> again;

    } while (again == 'y' || again == 'Y');

    return 0;
}
